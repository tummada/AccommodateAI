# === acmd ===

# Database (ต่อ postgres ของ vollos-core ผ่าน vollos-network)
DATABASE_URL=postgresql://acmd_user:CHANGE_ME@postgres:5432/vollos_prod

# Auth (vollos-core auth-service)
# RS-013: acmd-api delegates /auth/google, /auth/refresh, /auth/logout to vollos-core.
# This URL is where acmd-api fetches JWKS to verify access tokens.
# Dev (local monorepo):   VOLLOS_AUTH_URL=http://localhost:3004
# Prod (docker network):  VOLLOS_AUTH_URL=http://vollos-core-auth:3004
# Leave empty ONLY when running acmd-api in standalone dev mode with an
# ephemeral RSA pair (no real vollos-core instance). Unset in production = crash.
VOLLOS_AUTH_URL=http://localhost:3004

# RSA Keys for JWT signing/verification
# Production: generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | openssl pkey -outform PEM
# Development: leave empty — server generates ephemeral RSA pair on startup (sessions reset on restart)
AUTH_RSA_PRIVATE_KEY=
AUTH_RSA_PUBLIC_KEY=

# AI (Vertex AI)
GOOGLE_CLOUD_PROJECT=
VERTEX_AI_LOCATION=us-central1

# Encryption
ACMD_ENCRYPTION_KEY=

# App
NODE_ENV=development

# T-063 / T-101 / M3-001 §3.5 — Beta gate owner email.
# Sole identity allowed to:
#   1. Call PATCH /api/v1/admin/config (Rolling Cap D14 — bump beta_cap_current).
#   2. Bypass the Beta invite gate at POST /api/v1/onboarding (T-101) so the
#      owner is never locked out of production.
# Comparison: trim + lowercase both sides. Single value (no list support).
# Empty in non-prod = no bypass + admin endpoint returns 503 for everyone
# (fail-closed). MUST be set in production.
ACMD_OWNER_EMAIL=

# T-065 / SEC-001 — Trusted reverse-proxy allowlist.
# Comma-separated list of IPs / CIDRs that are allowed to set X-Forwarded-For.
# When the request's TCP peer IP is in this list, we read the rate-limit /
# audit IP from X-Forwarded-For. When the peer IP is NOT in this list (or
# this var is empty / unset), we IGNORE X-Forwarded-For and use the raw peer
# IP — defense against XFF spoofing that would otherwise bypass per-IP caps.
#
# Local dev / direct exposure: leave empty (default = trust nothing).
# Behind Caddy on the same host:    TRUSTED_PROXY_IPS=127.0.0.1,::1
# Behind a docker-compose network:  TRUSTED_PROXY_IPS=172.18.0.0/16
# Behind Cloudflare:                TRUSTED_PROXY_IPS=<full CF IP list>
TRUSTED_PROXY_IPS=
# CAN-SPAM physical postal address — required in every commercial email footer (15 USC 7704)
# Thai address used until Stripe Atlas + doola Delaware swap (Day 30+ trigger)
ADDRESS_POSTAL="VOLLOS · 295 Moo 3 · Mueang Si Khai, Warin Chamrap, Ubon Ratchathani 34190"

# T-070 / T-062 — Gmail Nodemailer OAuth2 (set via GitLab CI/CD Variables — Masked + Protected).
# Owned by vollos-core (handshake [2]); acmd never sees the raw values locally.
# Local dev: leave empty — Backend falls back to console transport (no real send).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER=

# Sender identity — hardcoded brand values (D6 strategy umbrella). Not secret.
EMAIL_FROM=noreply@vollos.ai
EMAIL_REPLY_TO=support@vollos.ai
