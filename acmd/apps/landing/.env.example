# AccommodateAI landing — public Vite environment variables.
# Vite bakes any VITE_* var into the client bundle at build time, so do NOT
# put server secrets here. Public URLs only.

# Base URL of the acmd-api service. Beta signup form POSTs to
# ${VITE_API_URL}/api/v1/beta-signup. Pattern follows D6.1 / D20 (flat-with-
# hyphen subdomain): accommodate-api.vollos.ai is the production host.
# Local dev: http://localhost:3101 (acmd-api Vite-less server).
VITE_API_URL=https://accommodate-api.vollos.ai

# Base URL of the acmd-web dashboard (used for the Sign-in link and the
# post-signup redirect). The landing lives at accommodate.vollos.ai while
# the dashboard lives at accommodate-app.vollos.ai (different subdomain),
# so this needs to be a full URL.
VITE_WEB_URL=https://accommodate-app.vollos.ai
