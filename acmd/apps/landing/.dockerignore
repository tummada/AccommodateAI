# T-061 — security: keep .env / node_modules / .git out of build context.
# Build context for this image is the monorepo root.

# Secrets
.env
.env.*
**/.env
**/.env.*
!**/.env.example

# Node + tooling
node_modules
**/node_modules
**/dist
**/.turbo
**/coverage

# VCS + editor
.git
.gitignore
.gitlab-ci.yml
.github
.vscode
.idea

# Lead workspace
_workspace
_board.md
security-check-output

# OS
.DS_Store
Thumbs.db

# Other apps
apps/api
apps/web
