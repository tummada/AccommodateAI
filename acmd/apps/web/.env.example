# AccommodateAI Web App — environment variables
# Copy to .env.local for local dev. NEVER commit real values.

# Google Identity Services OAuth Client ID (Web)
# Obtain from Google Cloud Console → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=

# Backend API base URL (no trailing slash) — serves /api/v1/auth/me + data endpoints
# Local dev:  http://localhost:3001  (acmd-api dev port — see apps/acmd-api/src/config.ts)
# Production: https://api.accommodate.ai
VITE_API_BASE_URL=http://localhost:3001

# Vollos auth service base URL (no trailing slash) — serves /auth/google, /auth/refresh, /auth/logout
# RS-013: auth endpoints moved from acmd-api to the shared vollos-core auth-service.
# Local dev:  http://localhost:3004  (vollos-core auth-service dev port)
# Production: https://auth.vollos.ai
VITE_VOLLOS_AUTH_URL=http://localhost:3004
