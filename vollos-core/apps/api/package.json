{
  "name": "@vollos/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "set -a && . ./.env && . ./.env.development && set +a && tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "pnpm --filter @vollos/db build && tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@vollos/db": "workspace:*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "hono": "^4.12.18",
    "hono-rate-limiter": "^0.5.3",
    "nodemailer": "^8.0.7",
    "sanitize-html": "^2.17.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.16.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
