# === vollos-core ===
# NOTE: .env.example must stay in sync with code. No real values — only
# empty placeholders + comments. Add an entry here whenever a new env var
# is introduced (rule J3 in CLAUDE.md).

# Runtime mode — production | development | test
NODE_ENV=production

# ---------- Database (postgres container) ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=vollos_prod

# Per-schema DB user passwords — consumed by scripts/init-db.sh on
# first postgres init. Source of truth is GitLab CI/CD Variables
# (masked + protected). NEVER commit real values.
AUTH_USER_PASSWORD=
VOLLOS_USER_PASSWORD=
ACMD_USER_PASSWORD=

# ---------- vollos-api (port 3001) ----------
DATABASE_URL=
# NOTE: PORT is NOT a top-level .env var.
# Source of truth is docker-compose.yml `environment: PORT:` per service
# (vollos-api=3001, auth-service=3004). A shared top-level PORT in .env
# would collide because both services load the same env_file.
# See T-005 fix and CLAUDE.md §E (port numbering).

# Cloudflare Turnstile (bot-protection on lead form)
TURNSTILE_SECRET_KEY=

# HMAC secret used to sign unsubscribe + deletion links
UNSUBSCRIBE_SECRET=

# Gmail OAuth2 (Nodemailer) — transactional email
GMAIL_USER=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional legacy SMTP fallback (only if Nodemailer OAuth2 is not used)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# ---------- auth-service (port 3004) ----------
AUTH_DATABASE_URL=

# RSA key pair for JWT RS256 signing. Store the PEM content as a single
# env var value (newlines escaped as \n). Source of truth is GitLab CI/CD
# Variables (masked + protected) — NEVER commit real PEM.
# Example how to encode:
#   awk 'NF {sub(/\r/,""); printf "%s\\n",$0}' private.pem
AUTH_RSA_PRIVATE_KEY=
AUTH_RSA_PUBLIC_KEY=

# Access / refresh token TTL in seconds (optional overrides).
# Defaults inside @vollos/auth if unset.
ACCESS_TTL=
REFRESH_TTL=

# Auth-service CORS allowlist (comma-separated). SEC-002 fail-closed:
# when NODE_ENV=production the service refuses to boot if this is empty.
# Dev default: http://localhost:3003. Example for production (must include
# every product subdomain that calls auth-service from the browser — D6.1
# pattern: {product}.vollos.ai (landing) + {product}-app.vollos.ai (web app)):
# AUTH_CORS_ORIGINS=https://vollos.ai,https://acmd.vollos.ai,https://accommodate.vollos.ai,https://accommodate-app.vollos.ai
AUTH_CORS_ORIGINS=http://localhost:3003

# URL that product repos use to fetch JWKS + route Google One-Tap callbacks.
# Production: https://auth.vollos.ai   Dev: http://localhost:3004
# (product repos read this — not vollos-core itself — but keep it here so
# deployments stay consistent.)
VOLLOS_AUTH_URL=

# ---------- Operations ----------
# Telegram (backup failure alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudflare R2 (off-site backup storage)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=

# ---------- Backup encryption (T-040) ----------
# Backups are GPG-encrypted on the VPS with an RSA-4096 public key before
# upload to R2. The VPS holds ONLY the public key (infra/backup-public.asc
# — safe to commit). The PRIVATE key lives OFFLINE with the owner and
# is the ONLY thing that can decrypt backups for restore.
#
# There is NO passphrase or private-key env var on the VPS. The public
# key needs no secret to use. See _workspace/T-040/RUNBOOK-key-setup.md
# for owner key generation.
#
# Optional: override the GPG recipient if the key UID ever changes.
# Default in backup.sh is "backup@vollos.ai".
GPG_RECIPIENT=
